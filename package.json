{
  "name": "ember-mcp",
  "version": "0.1.0",
  "description": "MCP server for Ember.js documentation, guides, and best practices",
  "keywords": [
    "ember",
    "emberjs",
    "documentation",
    "mcp",
    "model-context-protocol"
  ],
  "repository": "https://github.com/ember-tooling/ember-mcp",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "bin": {
    "ember-mcp": "./index.js"
  },
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.16",
    "release-plan": "^0.18.0",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "overrides": {
      "tar": "^7.5.9"
    }
  }
}
